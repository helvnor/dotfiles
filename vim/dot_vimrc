"" Keybindings
" NOTE: comments must not trail :map commands — vim treats them as part of the mapping
set mouse=
let mapleader = " "
map <F1> <nop>

" Window navigation: Ctrl-[h,j,k,l]
nnoremap <C-h> <C-W>h
nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-l> <C-W>l

" Window arrangement: Leader->Ctrl-[h,j,k,l]
nnoremap <leader><C-h> <C-W><S-h>
nnoremap <leader><C-j> <C-W><S-j>
nnoremap <leader><C-k> <C-W><S-k>
nnoremap <leader><C-l> <C-W><S-l>

" Window resize: Leader->[h,j,k,l]
nnoremap <leader>h <C-W>5<
nnoremap <leader>j <C-W>5+
nnoremap <leader>k <C-W>5-
nnoremap <leader>l <C-W>5>

" Tab management: Leader->t...
" tn = new, tc = close, t1-t5 = go to tab, tm1-tm5 = move tab, S-h/S-l = prev/next
nnoremap <leader>tn :tabnew<CR>
nnoremap <leader>tc :tabclose<CR>
nnoremap <leader>t1 :tabnext 1<CR>
nnoremap <leader>t2 :tabnext 2<CR>
nnoremap <leader>t3 :tabnext 3<CR>
nnoremap <leader>t4 :tabnext 4<CR>
nnoremap <leader>t5 :tabnext 5<CR>
nnoremap <leader>tm1 :tabmove 1<CR>
nnoremap <leader>tm2 :tabmove 2<CR>
nnoremap <leader>tm3 :tabmove 3<CR>
nnoremap <leader>tm4 :tabmove 4<CR>
nnoremap <leader>tm5 :tabmove 5<CR>
nnoremap <S-h> :tabprevious<CR>
nnoremap <S-l> :tabnext<CR>

" Copy and paste to clipboard
vnoremap <leader>cy "+y
map <leader>cp "+p

" Open file browser
nnoremap - :Explore<CR>

"" Buffer / Undo
set hidden
set noswapfile
set undofile
set undodir=~/.vim/undo

"" Indent / Format
set autoindent
set smartindent
set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
set backspace=indent,eol,start
set nofixeol

"" Searching
set showmatch
set incsearch
set ignorecase
set smartcase

"" Folding
set foldmethod=syntax
set foldlevelstart=99

"" UI
set laststatus=2
set cursorline
set wildmenu
set showcmd
set nowrap
set linebreak
set scrolloff=2

"" Numbers
set number
set relativenumber

"" Theme
syntax enable
set termguicolors
set background=dark
color slate

"" Spell check for txt and md files
set spelllang=en_gb
autocmd FileType markdown setlocal spell
autocmd FileType text setlocal spell
